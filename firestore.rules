rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. SECURITY CHECKS (The New Device OTP Flow)
    match /security_checks/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Handled by Admin SDK
    }

    // 2. USER PROFILES
    match /users/{uid} {
      // Anyone can see a user's name, pic, and status
      allow read: if request.auth != null;
      
      // Users can fully manage their own profile
      allow create, delete: if request.auth != null && request.auth.uid == uid;
      
      // Owners can update anything; others can only update specific 'handshake' fields if needed
      allow update: if request.auth != null && (
        request.auth.uid == uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['loginAttempt', 'fcmToken', 'status', 'lastSeen'])
      );
    }

    // 3. MESSAGES (Real-time Chat)
    match /messages/{chatId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        chatId.matches('.*' + request.auth.uid + '.*') || 
        exists(/databases/$(database)/documents/groups/$(chatId)/members/$(request.auth.uid))
      );
    }

    // 4. CALLS & WebRTC SIGNALING
    match /calls/{chatId} {
      allow read, write: if request.auth != null && (
        chatId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid)) ||
        (request.resource != null && (request.resource.data.callerId == request.auth.uid || request.resource.data.receiverId == request.auth.uid))
      );
      
      // Allow candidates sub-collection access for active participants
      match /candidates/{candidateId} {
        allow read, write: if request.auth != null; 
      }
    }

    // 5. CALL LOGS (History)
    match /call_logs/{logId} {
      // Users can only see logs where they are a participant
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      // Allow creation if the user is the one initiating/receiving the call
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
    }

    // 6. STATUS UPDATES (Stories)
    match /statuses/{statusId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // 7. PENDING REGISTRATIONS (OTP Verification)
    match /pending_registrations/{identifier} {
      allow read, write: if true; 
    }

    // 8. DEFAULT FALLBACK
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
